ofiles\":[]}]},{\"id\":\"agents\",\"label\":\"Agents\",\"source\":\"core\",\"tools\":[{\"id\":\"agents_list\",\"label\":\"agents_list\",\"description\":\"List agents\",\"source\":\"core\",\"defaultProfiles\":[]}]},{\"id\":\"media\",\"label\":\"Media\",\"source\":\"core\",\"tools\":[{\"id\":\"image\",\"label\":\"image\",\"description\":\"Image understanding\",\"source\":\"core\",\"defaultProfiles\":[\"coding\"]},{\"id\":\"tts\",\"label\":\"tts\",\"description\":\"Text-to-speech conversion\",\"source\":\"core\",\"defaultProfiles\":[]}]},{\"id\":\"plugin:wave\",\"label\":\"wave\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"tools\":[{\"id\":\"wave_add_conv_tabs\",\"label\":\"添加会话标签页\",\"description\":\"向 Wave 群聊添加会话标签页(快捷链接)\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_add_group_members\",\"label\":\"添加群成员\",\"description\":\"向 Wave 群聊添加成员\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_add_spreadsheet_sheet\",\"label\":\"添加工作表\",\"description\":\"向 Wave 表格文档中添加新的工作表\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_append_document\",\"label\":\"追加文档内容\",\"description\":\"向 Wave 文档末尾追加内容\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_append_spreadsheet\",\"label\":\"追加表格内容\",\"description\":\"向 Wave 表格末尾追加数据行\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_append_unravel\",\"label\":\"追加 Unravel 文档内容\",\"description\":\"向 Wave Unravel 文档末尾追加内容\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_ask_user\",\"label\":\"向用户发送交互卡片\",\"description\":\"向用户发送一张带按钮的交互式卡片,等待用户点击按钮后返回用户的选择。\\n适用场景:确认操作、单选/多选、让用户在几个选项中做出决策。\\n注意:此工具会阻塞等待用户响应,超时后返回错误。\\n按钮样式可选:default(默认灰色)、primary(蓝色)、danger(红色)、warning(黄色)、success(绿色)。\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_ask_user_form\",\"label\":\"向用户发送表单卡片\",\"description\":\"向用户发送一张包含表单字段的交互式卡片,等待用户填写并提交后返回表单数据。\\n支持的字段类型:input(文本输入)、textarea(多行输入)、select(下拉选择)、\\nmulti_select(多选下拉)、date(日期选择)、time(时间选择)、checkbox(复选框组)。\\n注意:此工具会阻塞等待用户提交,超时后返回错误。\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_authorize_user_scope\",\"label\":\"发起用户授权\",\"description\":\"发起 Wave 用户授权(auth.authorizeUserScope),可选等待授权回调并自动换取 user_token。\\n适用于需要 Authorization=user_token 的能力调用前置授权场景。\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_batch_get_calendar_events\",\"label\":\"批量获取事件详情\",\"description\":\"批量获取多个 Wave 日历事件的详细信息\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_cancel_calendar_event\",\"label\":\"取消日历事件\",\"description\":\"取消/删除 Wave 日历事件\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_convert_user_ids\",\"label\":\"转换用户 ID\",\"description\":\"在 Wave 的 user_id 和 union_id 之间互转\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_create_calendar\",\"label\":\"创建日历\",\"description\":\"创建新的 Wave 日历\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_create_calendar_event\",\"label\":\"创建日历事件\",\"description\":\"在 Wave 日历中创建事件\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_create_document\",\"label\":\"创建文档\",\"description\":\"在 Wave 中创建文档\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_create_group\",\"label\":\"创建 Wave 群聊\",\"description\":\"在 Wave 中创建群聊\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_create_markdown\",\"label\":\"创建 Markdown 文档\",\"description\":\"在 Wave 中创建 Markdown 文档\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_create_spreadsheet\",\"label\":\"创建表格\",\"description\":\"在 Wave 中创建表格文档\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_create_unravel\",\"label\":\"创建 Unravel 文档\",\"description\":\"创建 Wave Unravel 格式文档\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_delete_document\",\"label\":\"删除文档\",\"description\":\"删除 Wave 文档\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_delete_group\",\"label\":\"解散群聊\",\"description\":\"解散/删除 Wave 群聊\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_delete_spreadsheet_rows\",\"label\":\"删除表格行\",\"description\":\"从 Wave 表格中删除指定行\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_export_spreadsheet\",\"label\":\"导出表格\",\"description\":\"导出 Wave 表格文档为文件(异步操作,用 wave_get_export_spreadsheet_status 查询状态和下载链接)\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_get_authorized_user_info\",\"label\":\"获取授权用户信息\",\"description\":\"调用 auth.getUserInfo 查询当前授权用户信息(可显式传 user_token)。\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_get_calendar_event_detail\",\"label\":\"获取日历事件详情\",\"description\":\"获取 Wave 日历事件的详细信息\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_get_calendar_events\",\"label\":\"获取日历事件\",\"description\":\"获取 Wave 日历事件列表\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_get_calendar_list\",\"label\":\"获取日历列表\",\"description\":\"获取 Wave 日历列表\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":fals