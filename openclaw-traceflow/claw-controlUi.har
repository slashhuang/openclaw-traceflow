cription\":\"获取 Wave 群聊的当前公告内容\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_get_group_info\",\"label\":\"获取群信息\",\"description\":\"获取 Wave 群聊的详细信息(名称、头像、群主等)\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_get_group_members\",\"label\":\"获取群成员\",\"description\":\"获取 Wave 群聊的成员列表\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_get_import_doc_status\",\"label\":\"获取导入文档状态\",\"description\":\"查询 Wave 文档导入任务的状态\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_get_latest_user_authorization\",\"label\":\"查询最近授权回调\",\"description\":\"查询本进程中缓存的最近一次用户授权回调事件。\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_get_meeting_minutes\",\"label\":\"获取会议纪要\",\"description\":\"获取 Wave 会议纪要列表。需要用户授权(minutes:read 权限)。\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_get_meeting_transcript\",\"label\":\"获取会议转写\",\"description\":\"获取 Wave 会议纪要的转写内容。需要用户授权(minutes:read 权限)。\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_get_message\",\"label\":\"获取消息详情\",\"description\":\"获取 Wave 消息的详细内容\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_get_reaction_members\",\"label\":\"获取消息表情回复人员列表\",\"description\":\"获取 Wave 消息指定表情回复的人员列表,不指定 reaction_id 时返回所有类型\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_get_reactions\",\"label\":\"获取消息表情反应\",\"description\":\"获取 Wave 消息的表情反应列表\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_get_recurrence_events\",\"label\":\"获取循环事件\",\"description\":\"获取 Wave 日历中循环事件的实例列表\",\"source\":\"plugin\",\"pluginId\":\"wave\