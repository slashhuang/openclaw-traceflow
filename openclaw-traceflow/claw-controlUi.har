 消息。限制:非群主/管理员只能撤回自己24小时内的消息\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_remove_group_members\",\"label\":\"移除群成员\",\"description\":\"从 Wave 群聊中移除成员,或让机器人退出群聊\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_reply_message\",\"label\":\"回复消息\",\"description\":\"回复 Wave 中的指定消息\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_search_documents\",\"label\":\"检索文档\",\"description\":\"在 Wave 文档中检索内容\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_search_users\",\"label\":\"搜索 Wave 用户\",\"description\":\"在 Wave 通讯录中搜索用户信息\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_send_batch_message\",\"label\":\"批量发送消息\",\"description\":\"向多个 Wave 用户批量发送同一条消息。权限要求: im:batch_msg\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_send_message\",\"label\":\"发送 Wave 消息\",\"description\":\"向指定用户或群组发送文本/Markdown/图片/文件消息\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_send_notice\",\"label\":\"发送通知助手消息\",\"description\":\"向用户的通知助手发送卡片形式的通知消息(非聊天消息,显示在通知中心)\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_set_group_announcement\",\"label\":\"设置群公告\",\"description\":\"设置 Wave 群聊的公告内容\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_set_group_managers\",\"label\":\"设置群管理员\",\"description\":\"设置 Wave 群聊的管理员列表\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_transfer_group_owner\",\"label\":\"转移群主\",\"description\":\"将 Wave 群聊的群主转移给其他成员\",\"source\":\"plugin\",\"pluginId\":\"wave\",\"optional\":false,\"defaultProfiles\":[]},{\"id\":\"wave_update_calen