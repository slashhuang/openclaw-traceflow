{
  "$schema": "https://raw.githubusercontent.com/openclaw-traceflow/main/config-schema.json",
  "_comment": "OpenClaw TraceFlow 运行时配置示例",
  "_docs": "配置说明：config/README.md",

  "host": "0.0.0.0",
  "port": 3001,

  "openclawGatewayUrl": "http://localhost:18789",
  "openclawStateDir": "/Users/your-username/.openclaw/state",
  "openclawWorkspaceDir": "/Users/your-username/.openclaw/workspace",

  "accessMode": "none",

  "dataDir": "./data",

  "tokenEstimateBytesDivisor": 4,

  "workspaceWriteWhenAccessNoneEnabled": false,

  "sources": [
    {
      "type": "openclaw",
      "enabled": true,
      "config": {
        "sessionsDir": "/Users/your-username/.openclaw/agents/main/sessions"
      }
    }
  ],

  "im": {
    "enabled": true,
    "errorMonitor": {
      "enabled": true,
      "targetChatId": "oc_xxx",
      "minSeverity": "warning",
      "aggregateWindowMs": 30000,
      "patterns": {
        "promptError": true,
        "toolStatusError": true,
        "nonZeroExit": true,
        "stackTrace": true,
        "consecutiveFailures": true
      }
    },
    "channels": {
      "feishu": {
        "enabled": true,
        "appId": "cli_xxx",
        "appSecret": "xxx",
        "targetUserId": "ou_xxx",
        "receiveIdType": "open_id",
        "rateLimit": 10,
        "pushStrategy": {
          "sessionStart": false,
          "sessionMessages": true,
          "sessionEnd": true,
          "errorLogs": true,
          "warnLogs": false
        }
      },
      "dingtalk": {
        "enabled": false,
        "appKey": "ding_xxx",
        "appSecret": "xxx",
        "agentId": 1000001,
        "targetUserId": "@all",
        "pushStrategy": {
          "sessionMessages": false,
          "errorLogs": true
        }
      }
    }
  }
}
