{
  "$schema": "https://raw.githubusercontent.com/openclaw-traceflow/main/config-schema.json",
  "_comment": "OpenClaw TraceFlow 运行时配置示例 - 包含 IM 推送配置",

  "host": "0.0.0.0",
  "port": 3001,

  "openclawGatewayUrl": "http://localhost:18789",
  "openclawStateDir": "/Users/your-username/.openclaw/state",
  "openclawWorkspaceDir": "/Users/your-username/.openclaw/workspace",

  "accessMode": "none",

  "dataDir": "./data",

  "tokenEstimateBytesDivisor": 4,

  "workspaceWriteWhenAccessNoneEnabled": false,

  "sources": [
    {
      "type": "openclaw",
      "enabled": true,
      "config": {
        "sessionsDir": "/Users/your-username/.openclaw/agents/main/sessions"
      }
    }
  ],

  "im": {
    "enabled": true,
    "channels": {
      "feishu": {
        "enabled": true,
        "appId": "cli_xxx",
        "appSecret": "xxx",
        "targetUserId": "ou_xxx",
        "rateLimit": 10,
        "pushStrategy": {
          "sessionStart": false,
          "sessionMessages": true,
          "sessionEnd": true,
          "errorLogs": true,
          "warnLogs": false
        }
      }
    }
  }
}
