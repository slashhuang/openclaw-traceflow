{
  "$schema": "https://raw.githubusercontent.com/openclaw-traceflow/main/config-schema.json",
  "_comment": "OpenClaw TraceFlow 运行时配置 - 路径配置示例",
  
  "host": "0.0.0.0",
  "port": 3001,
  
  "openclawGatewayUrl": "http://localhost:18789",
  
  "accessMode": "none",
  
  "dataDir": "./data",
  
  "tokenEstimateBytesDivisor": 4,
  
  "workspaceWriteWhenAccessNoneEnabled": false,
  
  "sources": [
    {
      "type": "openclaw",
      "enabled": true,
      "config": {
        "sessionsDir": "/Users/huangxiaogang/.openclaw/agents/main/sessions"
      }
    }
  ],
  
  "im": {
    "enabled": false
  }
}
