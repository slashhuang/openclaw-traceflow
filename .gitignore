.env

# 同步等运行时日志
logs/
.last_boot_commit__pycache__/

# Python 缓存
__pycache__/
*.py[cod]

# Mac 桌面应用 (mac-app)
mac-app/dist/
mac-app/node_modules/
mac-app/icon.icns
mac-app/icon.iconset/
mac-app/.icon_*.png
