{
  "name": "openclaw-traceflow",
  "version": "0.1.0",
  "description": "OpenClaw TraceFlow — observability dashboard (sessions, skills, tokens, latency, logs). NestJS + React. Bilingual UI. See README.md.",
  "author": "slashhuang",
  "license": "MIT",
  "private": false,
  "bin": {
    "openclaw-traceflow": "./bin/cli.js",
    "openclaw-monitor": "./bin/cli.js"
  },
  "scripts": {
    "build": "nest build",
    "build:frontend": "cd frontend && vite build",
    "build:all": "pnpm run build && pnpm run build:frontend",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "restart:prod": "if pm2 describe openclaw-traceflow >/dev/null 2>&1; then pm2 restart openclaw-traceflow --update-env; else pm2 start dist/main.js --name openclaw-traceflow --restart-delay=3000 --max-restarts=10; fi",
    "dev": "concurrently \"nest start --watch\" \"cd frontend && vite\"",
    "dev:backend": "nest start --watch",
    "dev:frontend": "cd frontend && vite",
    "monitor": "node bin/cli.js",
    "monitor:dev": "nest start --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "docker:build": "docker build -t clawfamily/openclaw-traceflow:latest .",
    "docker:run": "docker run -d -p 3001:3001 --name openclaw-traceflow clawfamily/openclaw-traceflow:latest",
    "docker:push": "docker push clawfamily/openclaw-traceflow:latest",
    "deploy:docker": "pnpm run build:all && pnpm run docker:build && docker run -d -p 3001:3001 --restart always --name openclaw-traceflow clawfamily/openclaw-traceflow:latest",
    "deploy:pm2": "pnpm run build:all && if pm2 describe openclaw-traceflow >/dev/null 2>&1; then pm2 reload openclaw-traceflow --update-env; else pm2 start dist/main.js --name openclaw-traceflow --restart-delay=3000 --max-restarts=10; fi",
    "deploy:k8s": "kubectl apply -f k8s/",
    "release": "pnpm run build:all && pnpm pack",
    "clean": "rm -rf dist frontend/dist public/app",
    "reset": "pnpm run clean && rm -rf node_modules && pnpm install"
  },
  "dependencies": {
    "@ant-design/icons": "^6.0.0",
    "@ant-design/pro-layout": "^7.22.7",
    "antd": "^5.24.0",
    "dayjs": "^1.11.13",
    "react-intl": "^7.1.11",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.17",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/websockets": "^11.1.17",
    "axios": "^1.13.6",
    "chokidar": "^4.0.3",
    "express": "^5.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sql.js": "^1.14.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/sql.js": "^1.4.9",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^8.0.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
