{
  "name": "futu-openD",
  "version": "1.0.0",
  "description": "富途 OpenD 独立启动工具，支持前台/后台模式，跨环境一致管理",
  "main": "src/opend.js",
  "scripts": {
    "futu": "node scripts/start.js",
    "futu:bg": "node scripts/start.js --background",
    "futu:pm2": "pm2 start ecosystem.config.cjs",
    "futu:pm2:dev": "pm2 start ecosystem.config.cjs --env dev",
    "futu:pm2:local": "pm2 start ecosystem.config.cjs --env local",
    "start": "node scripts/start.js"
  },
  "keywords": [
    "futu",
    "opend",
    "富途",
    "quant",
    "trading"
  ],
  "author": "slashhuang",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.0.0"
  },
  "devDependencies": {
    "pm2": "^5.0.0"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
